
root NBC4(haveStaffCard: Bool, haveManagementCard: Bool, id: Int){

    enum MapType {
        TransHub,
        StdFloor,
    }

    floors: List = [Lobby, Floor2, ..., Floor80]
    // 10-20 same topology

    def f (a : Int) => a + 1
    let myInt = f 2

    def fib = fix fib: Int -> Int. {
        fun n: Int =>
          if n < 2 then 1
          else fib (n - 1) + fib (n - 2)
    }
    // ==> 55

    def fib (n: Int) =>
      if n < 2 then 1
      else fib (n - 1) + fib (n - 2)

    object MyClass {
      a: Int = 1
      b: Int = a + 1
    }

    fix MyClass: {a : Int; b: Int}. {
      a: Int = 1
      b: Int = MyClass.a + 1
    }

    station {
        relativeLocation: Float,
    }

    atomic-path {
        cost : Int,
        description : String?,
    }

    #forall($level in [4 .. 17]) {
        alias Floor$level := FloorZ1
    }

    // Define what means "TenantsOnly"
    constraint TenantsOnly{
        require myInt > 2 ...
        require haveStaffCard == true otherwise UNAUTHORIZED
    }

    // [Unauthorized, ReallyUnauthorized]

    // Define what means ManagementOnly 
    constraint ManagementOnly{ 
        require haveManagetmentCard == true otherwise UnauthorizedVisitExcepion
    } 

    // Define what means EmergencyEgress 
    constraint EmergencyEgress{ 
        require(circumstance == "Emergency", PathUnavailableException) 
    }
    
    constraint myConstraint(cond: Int) {
        require cond > myInt
    }
    
    // Actually:
    def myConstraint(cond: Int): Constraint = constraint {
        require cond > myInt;
    }

}