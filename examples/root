root TopoMap NBC4 is PureOffice{
    
    include "FloorZ1"
    include "FloorZ2"
    include "FloorZ3"
    include "FloorZ4"
    include "Lobby"
    include "Floor3"
    include "Floor29"
    include "Floor30"

    include "OP1"
    include "OP2"
    include "OP3"
    include "OP4"
    include "OEX" // Express
    include "OFR" // 29/30
    include "OS"

    EQ_ALL("Floor" + p"4~17", FloorZ1)
    EQ_ALL("Floor" + p"19~27", FloorZ2)
    EQ_ALL("Floor" + p"31~46", FloorZ3)
    EQ_ALL("Floor" + p"47~59", FloorZ4)

    // Define what means "TenantsOnly" 
    modifier TenantsOnly{ 
        require(haveStaffCard == true, UnauthorizedVisitException) 
    } 

    // Define what means ManagementOnly 
    modifier ManagementOnly{ 
        require(haveManagementCard == true, UnauthorizedVisitException) 
    } 

    // Define what means EmergencyEgress 
    modifier EmergencyEgress{ 
        require(circumstance == Emergency, PathUnavailableException) 
    } 
}