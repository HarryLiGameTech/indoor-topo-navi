root TopoMap NBC4 is PureOffice{


    input{
        bool haveStaffCard,
        bool haveManagementCard,
        string[] keys 
    }
    
    submap FloorZ1
    submap FloorZ2
    submap FloorZ3
    submap FloorZ4
    submap Lobby
    submap Floor3
    submap Floor29
    submap Floor30

    submap OP1
    submap OP2
    submap OP3
    submap OP4
    submap OEX // Express
    submap OFR // 29/30
    submap OS

    // TODO: Change syntax
    EQ_ALL("Floor" + p"4~17", FloorZ1)
    EQ_ALL("Floor" + p"19~27", FloorZ2)
    EQ_ALL("Floor" + p"31~46", FloorZ3)
    EQ_ALL("Floor" + p"47~59", FloorZ4)

    // Define what means "TenantsOnly" 
    constraint TenantsOnly{ 
        require(haveStaffCard == true, UNAUTHORIZED)
    } 

    // Define what means ManagementOnly 
    constraint ManagementOnly{ 
        require(haveManagementCard == true, UnauthorizedVisitException)
    } 

    // Define what means EmergencyEgress 
    constraint EmergencyEgress{ 
        require(circumstance == "Emergency", PathUnavailableException) 
    }

    constraint HasRoomKey(string roomName){
        require(keys.contains(roomName), UNAUTHORIZED)
    }
}