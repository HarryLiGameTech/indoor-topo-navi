
root NBC4(haveStaffCard: Bool, haveManagementCard: Bool, id: Int, aggregatedWeight: Int){

    enum MapType {
        TransHub,
        StdFloor,
    }


    def fib (n: Int) =>
      if n < 2 then 1
      else fib (n - 1) + fib (n - 2)

    object MyClass {
      a: Int = 1
      b: Int = a + 1
    }

    fix MyClass: {a : Int; b: Int}. {
      a: Int = 1
      b: Int = MyClass.a + 1
    }

    station {
        relativeLocation: Float,
    }

    atomic-path {
        cost : Int,
        description : String?,
    }



    // Define what means "TenantsOnly"
    constraint TenantsOnly{
        require haveStaffCard
    }

    // Define what means ManagementOnly 
    constraint ManagementOnly{ 
        require haveManagementCard
    }

    // Define what means CanFitIntoPassengerElevator
    constraint CanFitIntoPassengerElevator{
        require aggregatedWeight < 200
    }

    
    // Actually parsed as (after visiting):
    def CanFitIntoPassengerElevator(aggregatedWeight: Int): Bool = {
        aggregatedWeight < 200
    }

}