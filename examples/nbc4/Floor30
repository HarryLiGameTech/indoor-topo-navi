    // atomic-path [staircase_C -> staircase_C_outside] {cost = 5, movement = PullSecuredDoor} requires TenantsOnly

    // atomic-path [staircase_D_outside -> staircase_D] {cost = 10, movement = PushDoor}
    // atomic-path [staircase_D -> staircase_D_outside] {cost = 8, movement = PullSecuredDoor} requires TenantsOnly


    // atomic-path [OS_hall -> staircase_A] {cost = 3, movement = PushDoor}
    // atomic-path [staircase_A -> OS_hall] {cost = 5, movement = PullSecuredDoor} requires TenantsOnly

    atomic-path [OS_hall <-> OS_hall_outside] {cost = 2}
    atomic-path [OP3_hall <-> OP3_hall_outside] {cost = 2}
    atomic-path [OEX_hall <-> OEX_hall_outside] {cost = 2}
    
