    atomic-path [intersact1 <-> model] {cost = 2 + f(1)}
    atomic-path [SW_corner <-> model] {cost = 3}
    atomic-path [SW_corner <-> model] {cost = 3}
    atomic-path [bar <-> model] {cost = 6}
    atomic-path [bar <-> intersact3_south] {cost = 5}
    

